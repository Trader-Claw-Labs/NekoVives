<?xml version='1.0' encoding='windows-1252'?>
<!--
  Trader Claw WiX MSI installer definition.
  Build with: cargo wix --nocapture
  Requires: cargo install cargo-wix && wixtoolset.org v3.x
-->
<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>

  <Product
    Id='*'
    Name='Trader Claw'
    UpgradeCode='B4E7C2D1-9A3F-4E8B-A5C2-1D7F3E9B4A6C'
    Manufacturer='Trader Claw Labs'
    Language='1033'
    Codepage='1252'
    Version='!(bind.FileVersion.MainBinary)'>

    <Package
      Id='*'
      Keywords='Installer'
      Description='Trader Claw u2014 Crypto Trading Agent'
      Manufacturer='Trader Claw Labs'
      InstallerVersion='450'
      Languages='1033'
      Compressed='yes'
      InstallScope='perMachine'
      SummaryCodepage='1252'
      Platform='x64' />

    <MajorUpgrade
      Schedule='afterInstallInitialize'
      DowngradeErrorMessage='A newer version of [ProductName] is already installed. Setup will now exit.' />

    <Media Id='1' Cabinet='main.cab' EmbedCab='yes' />

    <Icon Id='ProductIcon' SourceFile='wix\trader-claw.ico' />
    <Property Id='ARPPRODUCTICON' Value='ProductIcon' />
    <Property Id='ARPHELPLINK' Value='https://github.com/Trader-Claw-Labs/Trader-Claw' />
    <Property Id='ARPURLINFOABOUT' Value='https://github.com/Trader-Claw-Labs/Trader-Claw' />
    <Property Id='ARPNOREPAIR' Value='1' />

    <Directory Id='TARGETDIR' Name='SourceDir'>
      <Directory Id='ProgramFiles64Folder'>
        <Directory Id='APPLICATIONFOLDER' Name='Trader Claw'>

          <Component Id='MainBinary' Guid='A3E8D7C2-1F4B-4E9A-B6D2-2E8C3F7A5B1D'>
            <File
              Id='MainBinary'
              Name='trader-claw.exe'
              DiskId='1'
              Source='target\x86_64-pc-windows-msvc\release\trader-claw.exe'
              KeyPath='yes' />
            <!-- Add to PATH for all users -->
            <Environment
              Id='PATH'
              Name='PATH'
              Value='[APPLICATIONFOLDER]'
              Permanent='no'
              Part='last'
              Action='set'
              System='yes' />
          </Component>

        </Directory>
      </Directory>
    </Directory>

    <Feature
      Id='MainProgram'
      Title='Trader Claw'
      Description='Installs the trader-claw binary.'
      Level='1'
      ConfigurableDirectory='APPLICATIONFOLDER'
      AllowAdvertise='no'
      Display='expand'
      Absent='disallow'>
      <ComponentRef Id='MainBinary' />
    </Feature>

    <SetProperty Id='ARPINSTALLLOCATION' Value='[APPLICATIONFOLDER]' After='CostFinalize' />

    <UI>
      <UIRef Id='WixUI_InstallDir' />
      <Publish Dialog='WelcomeDlg' Control='Next' Event='NewDialog' Value='InstallDirDlg' Order='99'>1</Publish>
      <Publish Dialog='InstallDirDlg' Control='Back' Event='NewDialog' Value='WelcomeDlg' Order='99'>1</Publish>
    </UI>
    <Property Id='WIXUI_INSTALLDIR' Value='APPLICATIONFOLDER' />

  </Product>
</Wix>
